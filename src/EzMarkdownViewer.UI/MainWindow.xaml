<Window x:Class="EzMarkdownViewer.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:EzMarkdownViewer.Core;assembly=EzMarkdownViewer.Core"
        xmlns:local="clr-namespace:EzMarkdownViewer.UI"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="{Binding WindowTitle}"
        Width="1200" Height="800"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Bg}"
        Foreground="{DynamicResource Brush.Fg}"
        TextOptions.TextFormattingMode="Display"
        Loaded="OnWindowLoaded">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <HierarchicalDataTemplate DataType="{x:Type core:FolderNode}"
                                  ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding DisplayName}" />
        </HierarchicalDataTemplate>

        <DataTemplate DataType="{x:Type core:MarkdownFileNode}">
            <TextBlock Text="{Binding DisplayName}" />
        </DataTemplate>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenFolderCommand}" />
        <KeyBinding Key="P" Modifiers="Control" Command="{x:Static local:MainWindow.FocusFilterCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
        <KeyBinding Key="Left" Modifiers="Alt" Command="{Binding GoBackCommand}" />
        <KeyBinding Key="Right" Modifiers="Alt" Command="{Binding GoForwardCommand}" />
        <KeyBinding Key="Up" Modifiers="Alt" Command="{Binding GoUpCommand}" />
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static local:MainWindow.FocusFilterCommand}"
                        Executed="FocusFilter_Executed" />
    </Window.CommandBindings>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Folder..."
                          InputGestureText="Ctrl+O"
                          Command="{Binding OpenFolderCommand}" />
                <MenuItem Header="Go _Up"
                          InputGestureText="Alt+Up"
                          Command="{Binding GoUpCommand}" />
                <Separator />
                <MenuItem Header="E_xit" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Refresh"
                          InputGestureText="F5"
                          Command="{Binding RefreshCommand}" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Register .md File Association"
                          Command="{Binding RegisterFileAssociationCommand}" />
                <MenuItem Header="_Unregister .md File Association"
                          Command="{Binding UnregisterFileAssociationCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About..." Click="About_Click" />
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Brush.Chrome}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="4">
                <Button Content="&#x2190;"
                        ToolTip="Back (Alt+Left)"
                        AutomationProperties.Name="Back"
                        Command="{Binding GoBackCommand}"
                        MinWidth="32"
                        Padding="6,2"
                        Margin="2,0" />
                <Button Content="&#x2192;"
                        ToolTip="Forward (Alt+Right)"
                        AutomationProperties.Name="Forward"
                        Command="{Binding GoForwardCommand}"
                        MinWidth="32"
                        Padding="6,2"
                        Margin="2,0" />
                <Button Content="&#x2191;"
                        ToolTip="Go Up (Alt+Up)"
                        AutomationProperties.Name="Go Up"
                        Command="{Binding GoUpCommand}"
                        MinWidth="32"
                        Padding="6,2"
                        Margin="2,0" />
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TreeColumn" Width="280" MinWidth="160" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="240" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource Brush.Bg}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <TextBlock Margin="16"
                               TextWrapping="Wrap"
                               Opacity="0.7"
                               Visibility="{Binding HasNoFolderOpen, Converter={StaticResource BoolToVisibility}}"
                               Text="No folder open. Use File &#x2192; Open Folder&#x2026; to begin." />

                    <DockPanel Visibility="{Binding HasFolderOpen, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel DockPanel.Dock="Top"
                                    Orientation="Horizontal"
                                    Margin="4,4,4,0">
                            <Button Content="Expand all"
                                    ToolTip="Expand all loaded folders"
                                    AutomationProperties.Name="Expand All"
                                    Command="{Binding ExpandAllCommand}"
                                    Padding="6,2"
                                    Margin="0,0,4,0" />
                            <Button Content="Collapse all"
                                    ToolTip="Collapse all folders"
                                    AutomationProperties.Name="Collapse All"
                                    Command="{Binding CollapseAllCommand}"
                                    Padding="6,2" />
                        </StackPanel>

                        <TextBox DockPanel.Dock="Top"
                                 x:Name="FilterBox"
                                 Margin="4"
                                 Padding="4,2"
                                 ToolTip="Filter files and folders (Ctrl+P, case-insensitive)"
                                 AutomationProperties.Name="Filter"
                                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />

                        <TreeView x:Name="DirectoryTree"
                                  ItemsSource="{Binding Roots}"
                                  BorderThickness="0"
                                  SelectedItemChanged="DirectoryTree_SelectedItemChanged">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="{x:Type TreeViewItem}">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVisibility}}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>
                    </DockPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ShowsPreview="False" />

            <Border Grid.Column="2">
                <wv2:WebView2 x:Name="ContentView" />
            </Border>
        </Grid>
    </DockPanel>
</Window>
