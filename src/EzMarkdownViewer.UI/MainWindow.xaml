<Window x:Class="EzMarkdownViewer.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:EzMarkdownViewer.Core;assembly=EzMarkdownViewer.Core"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="{Binding WindowTitle}"
        Width="1200" Height="800"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Bg}"
        Foreground="{DynamicResource Brush.Fg}"
        TextOptions.TextFormattingMode="Display"
        Loaded="OnWindowLoaded">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <HierarchicalDataTemplate DataType="{x:Type core:FolderNode}"
                                  ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding DisplayName}" />
        </HierarchicalDataTemplate>

        <DataTemplate DataType="{x:Type core:MarkdownFileNode}">
            <TextBlock Text="{Binding DisplayName}" />
        </DataTemplate>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenFolderCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </Window.InputBindings>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Folder..."
                          InputGestureText="Ctrl+O"
                          Command="{Binding OpenFolderCommand}" />
                <Separator />
                <MenuItem Header="E_xit" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Refresh"
                          InputGestureText="F5"
                          Command="{Binding RefreshCommand}" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Register .md File Association"
                          Command="{Binding RegisterFileAssociationCommand}" />
                <MenuItem Header="_Unregister .md File Association"
                          Command="{Binding UnregisterFileAssociationCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About..." Click="About_Click" />
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TreeColumn" Width="280" MinWidth="160" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="240" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource Brush.Bg}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <TextBlock Margin="16"
                               TextWrapping="Wrap"
                               Opacity="0.7"
                               Visibility="{Binding HasNoFolderOpen, Converter={StaticResource BoolToVisibility}}"
                               Text="No folder open. Use File &#x2192; Open Folder&#x2026; to begin." />

                    <TreeView x:Name="DirectoryTree"
                              ItemsSource="{Binding Roots}"
                              BorderThickness="0"
                              SelectedItemChanged="DirectoryTree_SelectedItemChanged"
                              Visibility="{Binding HasFolderOpen, Converter={StaticResource BoolToVisibility}}">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="{x:Type TreeViewItem}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ShowsPreview="False" />

            <Border Grid.Column="2">
                <wv2:WebView2 x:Name="ContentView" />
            </Border>
        </Grid>
    </DockPanel>
</Window>
